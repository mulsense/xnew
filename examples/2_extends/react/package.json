{
  "name": "xnew-example-react",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "React (Vite + TypeScript) hosts an xnew scene. npm install && npm run dev, then open the shown URL.",
  "scripts": {
    "sync-xnew": "node sync-xnew.js",
    "predev": "npm run sync-xnew",
    "prebuild": "npm run sync-xnew",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mulsense/xnew": "file:../../../",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
